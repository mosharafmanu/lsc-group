{
    "key": "group_mega_menu",
    "title": "Menu Item Settings",
    "fields": [
        {
            "key": "field_mega_menu_type",
            "label": "Menu Type",
            "name": "menu_type",
            "type": "button_group",
            "instructions": "Regular keeps the standard WordPress dropdown built from this item's child menu items. Mega Menu replaces that dropdown with a full-width mega panel built from the fields below (child menu items are ignored).",
            "required": 0,
            "choices": {
                "regular": "Regular Menu",
                "mega": "Mega Menu"
            },
            "default_value": "regular",
            "allow_null": 0,
            "layout": "horizontal",
            "return_format": "value"
        },
        {
            "key": "field_mega_heading",
            "label": "Mega Heading",
            "name": "mega_heading",
            "type": "text",
            "instructions": "Optional. Leave blank to use this menu item's label as the panel heading.",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_mega_menu_type",
                        "operator": "==",
                        "value": "mega"
                    }
                ]
            ],
            "placeholder": "Finance Products"
        },
        {
            "key": "field_mega_columns",
            "label": "Columns",
            "name": "mega_columns",
            "type": "button_group",
            "instructions": "Number of cards per row on desktop.",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_mega_menu_type",
                        "operator": "==",
                        "value": "mega"
                    }
                ]
            ],
            "choices": {
                "columns-2": "2",
                "columns-3": "3",
                "columns-4": "4",
                "columns-5": "5"
            },
            "default_value": "columns-4",
            "allow_null": 0,
            "layout": "horizontal",
            "return_format": "value"
        },
        {
            "key": "field_mega_source",
            "label": "Cards Source",
            "name": "mega_source",
            "type": "button_group",
            "instructions": "Pull cards automatically from a post type, or build them manually.",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_mega_menu_type",
                        "operator": "==",
                        "value": "mega"
                    }
                ]
            ],
            "choices": {
                "post_type": "From Post Type",
                "manual": "Manual"
            },
            "default_value": "post_type",
            "allow_null": 0,
            "layout": "horizontal",
            "return_format": "value"
        },
        {
            "key": "field_mega_post_type",
            "label": "Post Type",
            "name": "mega_post_type",
            "type": "select",
            "instructions": "Which post type the cards are pulled from. New post types added in future appear here automatically.",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_mega_source",
                        "operator": "==",
                        "value": "post_type"
                    }
                ]
            ],
            "choices": {},
            "default_value": "finance_product",
            "allow_null": 0,
            "multiple": 0,
            "ui": 1,
            "ajax": 0,
            "return_format": "value"
        },
        {
            "key": "field_mega_selection",
