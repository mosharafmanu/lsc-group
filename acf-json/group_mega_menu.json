            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_mega_source",
                        "operator": "==",
                        "value": "post_type"
                    }
                ]
            ],
            "choices": {
                "all": "Latest",
                "selected": "Selected"
            },
            "default_value": "all",
            "allow_null": 0,
            "layout": "horizontal",
            "return_format": "value"
        },
        {
            "key": "field_mega_selected_posts",
